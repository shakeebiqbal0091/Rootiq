# =============================================================================
# DevOps Intelligence Agent — Environment Variables
# Copy to .env and fill in your credentials.
# All tools degrade gracefully to mock data when credentials are absent.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (required to run demo — agent cannot analyse failures without this)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google Cloud / Gemini (production swap — replace Anthropic SDK)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-exp

# -----------------------------------------------------------------------------
# GitLab
# Personal access token with 'api' scope
# GITLAB_PROJECT_ID: numeric project ID (find under Settings > General)
# GITLAB_WEBHOOK_SECRET: arbitrary shared secret for webhook validation
# -----------------------------------------------------------------------------
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=
GITLAB_PROJECT_ID=

# GitLab Duo MCP Server (required for MCP integration)
# Your top-level GitLab group path e.g. "mygroup" (not the full URL)
# Enable GitLab Duo: Settings > General > GitLab Duo > Turn on
# Enable beta features: Settings > General > Beta features > Turn on
# Free 30-day Ultimate trial: https://about.gitlab.com/free-trial/
GITLAB_DUO_NAMESPACE=

# -----------------------------------------------------------------------------
# Elasticsearch
# For local dev: http://localhost:9200 (no auth needed with docker-compose)
# For Elastic Cloud: set ELASTIC_URL to your cloud endpoint + ELASTIC_API_KEY
# -----------------------------------------------------------------------------
ELASTIC_URL=http://localhost:9200
ELASTIC_API_KEY=
ELASTIC_LOG_INDEX=pipeline-logs-*

# -----------------------------------------------------------------------------
# MongoDB
# For local dev: mongodb://localhost:27017/devops_agent
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/devops_agent
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/devops_agent
MONGODB_DB=devops_agent

# -----------------------------------------------------------------------------
# Arize Phoenix (LLM observability)
# Get API key + space ID from https://app.phoenix.arize.com
# -----------------------------------------------------------------------------
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_MODEL_ID=devops-intelligence-agent
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# -----------------------------------------------------------------------------
# Fivetran (enriched external context — Jira, PagerDuty, DB metrics)
# Get API key + secret from https://fivetran.com/account/settings
# -----------------------------------------------------------------------------
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# -----------------------------------------------------------------------------
# Agent runtime
# LOG_LEVEL: debug | info | warn | error
# WEBHOOK_PORT: port for Express server receiving GitLab pipeline hooks
# -----------------------------------------------------------------------------
WEBHOOK_PORT=3000
LOG_LEVEL=info
NODE_ENV=development
