{
  "name": "devops-intelligence-agent",
  "version": "1.0.0",
  "description": "DevOps Intelligence Agent - An AI agent that wakes up when a GitLab CI pipeline fails, finds the root cause by querying Elastic logs and MongoDB incident history, enriches context via Fivetran, synthesizes a fix with Gemini/Claude, opens a GitLab issue or patch PR, and logs every reasoning step to Arize for auditability.",
  "main": "agent/index.js",
  "type": "module",
  "scripts": {
    "demo": "node scripts/demo-failure.js",
    "demo:oom": "node scripts/demo-failure.js --scenario oom",
    "demo:db": "node scripts/demo-failure.js --scenario db",
    "demo:test": "node scripts/demo-failure.js --scenario test",
    "test": "node scripts/test-integrations.js",
    "setup:db": "node scripts/setup-db.js",
    "webhook": "node agent/webhook-server.js",
    "start": "node agent/webhook-server.js",
    "dashboard": "cd dashboard && npm run dev",
    "docker:up": "docker-compose up --build",
    "docker:obs": "docker-compose --profile observability up --build"
  },
  "keywords": [
    "devops",
    "ai",
    "agent",
    "gitlab",
    "elasticsearch",
    "mongodb",
    "arize",
    "fivetran",
    "gemini",
    "claude"
  ],
  "author": "DevOps Intelligence Agent Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mongodb": "^5.0.0",
    "node-fetch": "^3.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}
